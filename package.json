{
  "name": "jjugumeong-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.17.0",
  "dependencies": {
    "react": "latest",
    "react-dom": "latest",
    "vinext": "latest",
    "react-server-dom-webpack": "latest",
    "@vinext/cloudflare": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vite": "latest",
    "@vitejs/plugin-react": "latest",
    "@vitejs/plugin-rsc": "latest",
    "@cloudflare/vite-plugin": "latest",
    "wrangler": "latest"
  },
  "type": "module",
  "scripts": {
    "prepare:game": "node tools/prepare-web-build.mjs",
    "dev": "vinext dev",
    "build": "vinext build && node tools/copy-hosting-config.mjs",
    "start": "wrangler dev --config dist/server/wrangler.json",
    "deploy": "vinext-cloudflare deploy --config dist/server/wrangler.json"
  }
}
